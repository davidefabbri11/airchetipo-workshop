generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique
  email      String   @unique
  name       String?
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile?
  meals      Meal[]

  @@map("users")
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  INTENSE
}

enum Goal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  REDUCE_FAT
  MAINTAIN
}

enum MealStatus {
  PENDING
  ANALYZED
}

enum AdequacyLevel {
  ADEQUATE
  EXCESSIVE
  INSUFFICIENT
}

model Meal {
  id                        String          @id @default(uuid())
  userId                    String
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl                  String
  status                    MealStatus      @default(PENDING)
  analyzedAt                DateTime?
  totalCalories             Float?
  totalProteins             Float?
  totalCarbs                Float?
  totalFats                 Float?
  adequacy                  AdequacyLevel?
  consumptionFrequency      String?
  remainingBudgetAtAnalysis Int?
  components                MealComponent[]
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  @@map("meals")
}

model MealComponent {
  id               String  @id @default(uuid())
  mealId           String
  meal             Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name             String
  estimatedGrams   Float
  calories         Float
  proteins         Float
  carbs            Float
  fats             Float
  openFoodFactsId  String?
  createdAt        DateTime @default(now())

  @@map("meal_components")
}

model Profile {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  height        Float
  weight        Float
  age           Int
  activityLevel ActivityLevel
  goal             Goal
  targetCalories   Int?
  goalDescription  String?
  cuisines         String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("profiles")
}
